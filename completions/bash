_claude_sandbox() {
    local commands="init new start stop list build remove logs link claude-md uninstall status help"
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"

    case "$prev" in
        start|stop|remove|link|claude-md)
            local base
            base=$(grep "^CLAUDE_SANDBOX_BASE=" ~/.config/claude-sandbox/config 2>/dev/null \
                   | cut -d= -f2 | tr -d '"')
            local projects
            projects=$(ls "$base" 2>/dev/null)
            COMPREPLY=($(compgen -W "$projects" -- "$cur"))
            ;;
        *)
            COMPREPLY=($(compgen -W "$commands" -- "$cur"))
            ;;
    esac
}
complete -F _claude_sandbox claude-sandbox
